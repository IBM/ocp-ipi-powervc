File: ocp-ipi-powervc/IBM-DNS.go
Line: 134 to 150
Type: potential_issue
Severity: major

Comment:
Returning uninitialized slice element on error can cause nil dereference.

When initIBMDNSService fails, the function returns dns which was initialized with make([]*IBMDNS, 1). This creates a slice with one nil element. Callers iterating over the returned slice without checking for nil elements will encounter a nil pointer dereference.

Consider either:
1. Return an empty slice on error, or
2. Return nil for the slice on error



🛡️ Proposed fix

 func innerNewIBMDNS(services Services) ([]IBMDNS, []error) {
 	var (
-		dns           []*IBMDNS
+		dns           []IBMDNS = make([]IBMDNS, 0)
 		errs          []error
 		dnsSvc        *dnssvcsv1.DnsSvcsV1
 		dnsRecordsSvc *dnsrecordsv1.DnsRecordsV1
 		err           error
 	)
 
-	dns = make([]*IBMDNS, 1)
-	errs = make([]error, 1)
+	errs = make([]error, 0)
 
 	dnsSvc, dnsRecordsSvc, err = initIBMDNSService(services)
 	if err != nil {
-		errs[0] = err
+		errs = append(errs, err)
 		return dns, errs
 	}
 
-	dns[0] = &IBMDNS{
+	dns = append(dns, &IBMDNS{
 		services:      services,
 		dnsSvc:        dnsSvc,
 		dnsRecordsSvc: dnsRecordsSvc,
-	}
+	})
 
 	return dns, errs
 }

